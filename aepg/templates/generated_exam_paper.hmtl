<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ paper.title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #fff;
            padding: 40px;
        }
        h2 {
            font-weight: bold;
            margin-bottom: 30px;
        }
        .question {
            margin-bottom: 25px;
            border-bottom: 1px solid #ccc;
            padding-bottom: 15px;
        }
        .options {
            margin-left: 20px;
        }
    </style>
</head>
<body>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ paper.title }}</h2>
        <div class="d-flex gap-2">
            <form action="{{ url_for('delete_all_exam_questions') }}" method="POST" onsubmit="return confirm('Delete all questions?');">
                <button class="btn btn-danger btn-sm">🗑️ Delete All</button>
            </form>
            <a href="{{ url_for('dashboard') }}" class="btn btn-secondary btn-sm">← Dashboard</a>
            <a href="{{ url_for('download_exam_pdf') }}" class="btn btn-success btn-sm">⬇️ Download PDF</a>
        </div>
    </div>

    {% if questions %}
        {% for question in questions %}
            <div class="question">
                <p><strong>Q{{ loop.index }}:</strong> {{ question.question_text }} ({{ question.marks }} Marks)</p>

                {% if question.question_type == 'mcq' %}
                <div class="options">
                    <div>A. {{ question.option_a }}</div>
                    <div>B. {{ question.option_b }}</div>
                    <div>C. {{ question.option_c }}</div>
                    <div>D. {{ question.option_d }}</div>
                </div>
                {% endif %}

                <form action="{{ url_for('delete_exam_question', question_id=question.id) }}" method="POST" class="mt-2">
                    <button class="btn btn-outline-danger btn-sm">🗑️ Delete</button>
                </form>
            </div>
        {% endfor %}
    {% else %}
        <div class="alert alert-info">No questions found to generate the exam.</div>
    {% endif %}

</body>
</html>
